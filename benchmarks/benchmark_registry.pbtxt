# ============================================================================
# DMA-style d2h/h2d benchmark — 13 groups mirroring jax_dma_kv_cache_benchmark
# (per-device pinned_host placement, lock_buffers=true default). Remove after use.
# ============================================================================

# ---- test_kv_cache groups (shape 16,128,8,2,128, shard_axis=2) ----
benchmarks {
  name: "dma_kv_bf16"
  description: "DMA-style d2h/h2d, 64 layers bf16, shape 16x128x8x2x128"
  owner: "raiden-dev"
  workload {
    action: "./ml_actions/actions/workload_executors/bazel"
    action_inputs { key: "target" value: "//tpu_raiden/benchmarks:multi_host_perf_test_oss" }
    action_inputs { key: "runtime_flags" value: "--cache_shape=16,128,8,2,128 --num_layers=64 --dtype=bfloat16 --shard_axis=2 --iters=100 --warmup=3" }
  }
  environment_configs {
    id: "tpu-v5e-single-node"
    runner_label: "linux-x86-ct5lp-224-8tpu"
    container_image: "us-docker.pkg.dev/ml-oss-artifacts-transient/ml-public-testing-container/ml-build:939285342"
    workload_action_inputs { key: "bazel_run_flags" value: "-c opt --config=oss" }
  }
  metrics { name: "d2h_time_sec" unit: "s" stats { stat: MEAN } }
  metrics { name: "h2d_time_sec" unit: "s" stats { stat: MEAN } }
  metrics { name: "d2h_throughput_gbps" unit: "Gbps" stats { stat: MEAN } }
  metrics { name: "h2d_throughput_gbps" unit: "Gbps" stats { stat: MEAN } }
}

