Testing/
.cache/

# gitignore template for Bazel build system
# website: https://bazel.build/

# Ignore all bazel-* symlinks. There is no full list since this can change
# based on the name of the directory bazel is cloned into.
bazel-*
MODULE.bazel.lock

# Directories for the Bazel IntelliJ plugin containing the generated
# IntelliJ project files and plugin configuration. Separate directories are
# for the IntelliJ, Android Studio and CLion versions of the plugin.
/.ijwb/
/.aswb/
/.clwb/

# Custom ignores
/jax/
/xla/

# Generated Python protobuf modules copied by build.sh
/tpu_raiden/rpc/raiden_service_pb2.py
/tpu_raiden/rpc/controller_service_pb2.py
/tpu_raiden/rpc/coordination_pb2.py
/tpu_raiden/rpc/coordination_pb2_grpc.py

# Python bytecode caches
**/__pycache__/
